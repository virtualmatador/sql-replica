SET @r = 'Engine of "ticket" is ok.';
ALTER TABLE `demo`.`ticket` ADD `_sql_id` int unsigned COMMENT 'TICKET_ID', ADD `_sql_title` varchar(64) DEFAULT 'untitled' COMMENT 'TICKET_TITLE', ADD `_sql_status` varchar(16) DEFAULT 'open' COMMENT 'TICKET_STATUS';
ALTER TABLE `demo`.`ticket` RENAME COLUMN `_sql_` to `_sql__drop__sql_`;
SET @r = 'All columns in "ticket" have prefix.';
ALTER TABLE `demo`.`ticket` RENAME COLUMN `_sql_id` to `id`, RENAME COLUMN `_sql_title` to `title`, RENAME COLUMN `_sql_status` to `status`;
SET @r = 'No extra foreign keys in "ticket".';
ALTER TABLE `demo`.`ticket` MODIFY `id` int unsigned not null auto_increment COMMENT 'TICKET_ID' FIRST, MODIFY `title` varchar(64) DEFAULT 'untitled' not null COMMENT 'TICKET_TITLE' AFTER `id`, MODIFY `status` varchar(16) DEFAULT 'open' not null COMMENT 'TICKET_STATUS' AFTER `title`, ADD primary key (`id`), DROP COLUMN `_sql__drop__sql_`;
SET @r = 'Table "ticket" is ok.';
