CREATE DATABASE `demo`;
USE `demo`;
SET @r = 'No extra routine.';
SET @r = 'Routine double_value absence is ok.';
DELIMITER <delimiter>
CREATE FUNCTION `demo`.`double_value`(`input_value` int) RETURNS int DETERMINISTIC NO SQL SQL SECURITY INVOKER BEGIN RETURN input_value * 2; END <delimiter>
