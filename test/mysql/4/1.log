DELIMITER <delimiter>
CREATE PROCEDURE `demo`.`set_value`(IN `input_value` int, OUT `output_value` int) MODIFIES SQL DATA SQL SECURITY INVOKER BEGIN SET output_value = input_value; END <delimiter>
DELIMITER ;
ALTER PROCEDURE `demo`.`set_value` COMMENT '
